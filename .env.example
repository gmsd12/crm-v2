# =========================
# Django core
# =========================
# local | prod
DJANGO_ENV=local

# Используйте длинный секрет в реальных окружениях
DJANGO_SECRET_KEY=unsafe-dev-key-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Язык/время
DJANGO_LANGUAGE_CODE=ru-ru
DJANGO_TIME_ZONE=Europe/Warsaw
DJANGO_USE_I18N=true
DJANGO_USE_TZ=true

# Безопасность (для prod обычно true)
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_PROXY_SSL_HEADER=false

# =========================
# Database
# =========================
# Примеры:
# sqlite: DATABASE_URL=sqlite:///db.sqlite3
# postgres: DATABASE_URL=postgres://user:pass@127.0.0.1:5432/crm
DATABASE_URL=sqlite:///config/db.sqlite3
DJANGO_STATIC_ROOT=/opt/crm/crm/staticfiles

# =========================
# CORS / CSRF
# =========================
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =========================
# JWT / Auth
# =========================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30
JWT_ROTATE_REFRESH_TOKENS=true
JWT_BLACKLIST_AFTER_ROTATION=true
JWT_UPDATE_LAST_LOGIN=true

JWT_REFRESH_COOKIE_NAME=refresh
JWT_REFRESH_COOKIE_DOMAIN=
JWT_REFRESH_COOKIE_SAMESITE=Lax
JWT_REFRESH_COOKIE_SECURE=false
JWT_REFRESH_COOKIE_HTTPONLY=true
JWT_REFRESH_COOKIE_PATH=/

# =========================
# API / docs / logging
# =========================
API_TITLE=CRM V2 API
API_DESCRIPTION=API documentation for CRM V2
API_VERSION=0.1.0
LOG_LEVEL=INFO

# =========================
# API pagination / limits
# =========================
PARTNER_API_THROTTLE_RATE=120/min
PARTNER_LEADS_PAGE_SIZE=50
PARTNER_LEADS_MAX_PAGE_SIZE=200

API_PAGE_SIZE=50
API_MAX_PAGE_SIZE=200
LEADS_BULK_STATUS_CHANGE_MAX_IDS=500

# =========================
# Notifications
# =========================
NOTIFICATIONS_MANAGER_NO_ACTIVITY_THRESHOLD=15
NOTIFICATIONS_PARTNER_DUPLICATE_THRESHOLD=10
NOTIFICATIONS_PARTNER_DUPLICATE_WINDOW_MINUTES=60
NOTIFICATIONS_BULK_SUMMARY_THRESHOLD=20

# =========================
# Celery / Redis
# =========================
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_NOTIFICATIONS_OUTBOX_PROCESS_INTERVAL_SECONDS=15
CELERY_NOTIFICATIONS_OUTBOX_PROCESS_LIMIT=200
CELERY_TASK_ALWAYS_EAGER=false

# Планировщик задач уведомлений
CELERY_NOTIFICATIONS_PROCESS_DUE_INTERVAL_SECONDS=10
CELERY_NOTIFICATIONS_PROCESS_DUE_LIMIT=500
CELERY_NOTIFICATIONS_EMIT_OVERDUE_INTERVAL_SECONDS=300
CELERY_NOTIFICATIONS_EMIT_OVERDUE_LIMIT=500
CELERY_NOTIFICATIONS_MANAGER_NO_ACTIVITY_INTERVAL_SECONDS=120
CELERY_NOTIFICATIONS_MANAGER_NO_ACTIVITY_LIMIT=500
